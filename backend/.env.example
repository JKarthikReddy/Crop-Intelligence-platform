# ── Crop Intelligence Backend — Environment Variables ────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Application ──────────────────────────────────────────────────
APP_NAME=Crop Intelligence API
ENV=development
DEBUG=true

# ── Database (PostgreSQL + PostGIS) ──────────────────────────────
DATABASE_URL=postgresql+asyncpg://crop:crop@localhost:5432/cropdb

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── External APIs ────────────────────────────────────────────────
# OpenWeather (https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Sentinel Hub (https://www.sentinel-hub.com/)
SENTINEL_CLIENT_ID=your_sentinel_client_id_here
SENTINEL_CLIENT_SECRET=your_sentinel_client_secret_here
